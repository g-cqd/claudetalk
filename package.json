{
  "name": "claudetalk",
  "version": "0.1.0",
  "description": "Inter-Claude messaging over MCP. Runs on Bun.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "module": "src/server.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/g-cqd/claudetalk.git"
  },
  "homepage": "https://github.com/g-cqd/claudetalk",
  "bugs": {
    "url": "https://github.com/g-cqd/claudetalk/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "model-context-protocol",
    "bun",
    "typescript",
    "agent",
    "multi-agent",
    "messaging"
  ],
  "scripts": {
    "serve": "bun run src/server.ts",
    "install:user": "bun run bin/cli.ts install --scope user",
    "install:project": "bun run bin/cli.ts install --scope project",
    "uninstall:user": "bun run bin/cli.ts uninstall --scope user",
    "whoami": "bun run bin/cli.ts whoami",
    "doctor": "bun run bin/cli.ts doctor",
    "tail": "bun run bin/cli.ts tail",
    "web": "bun run bin/cli.ts web",
    "log": "bun run bin/cli.ts log",

    "test": "bun test --isolate",
    "test:unit": "bun test --isolate test/unit",
    "test:integration": "bun test --isolate test/integration",
    "test:coverage": "bun test --coverage --isolate",

    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check --diagnostic-level=error ./src ./bin ./hooks ./scripts ./test",
    "lint:fix": "bunx biome check --write ./src ./bin ./hooks ./scripts ./test",
    "lint:unused": "bunx knip",
    "lint:unused:fix": "bunx knip --fix",
    "lint:duplication": "bunx jscpd src bin hooks scripts",
    "lint:size": "bun scripts/check-file-size.ts",

    "test:mutate": "bunx stryker run",
    "test:mutate:changed": "bunx stryker run --incremental",

    "audit": "bun run lint && bun run typecheck && bun run lint:unused && bun run lint:duplication && bun run lint:size && bun run test:coverage",
    "audit:report": "mkdir -p reports && bun run lint && bun run typecheck && bunx knip --reporter json > reports/knip.json; bunx jscpd src bin hooks scripts; bun run test:coverage",
    "ci": "bun run lint && bun run typecheck && bun run lint:unused && bun run lint:size && bun run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@stryker-mutator/core": "^9.6.1",
    "@types/bun": "^1.3.14",
    "jscpd": "^4.2.2",
    "knip": "^6.14.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
